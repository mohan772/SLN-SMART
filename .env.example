# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/sln?retryWrites=true&w=majority

# JWT auth
JWT_SECRET=your_super_secret_jwt_key
NODE_ENV=production
PORT=5000

# Razorpay (optional, if using payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMS OTP (optional)
MSG91_AUTH_KEY=your_msg91_api_key

# Cloudinary (optional, if used)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
EMAIL_FROM=noreply@yourdomain.com

# Frontend
VITE_API_URL=https://your-backend-service.onrender.com/api
VITE_RAZORPAY_KEY_ID=your_razorpay_public_key
VITE_APP_NAME=SLN Smart Vegetable Shop
